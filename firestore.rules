rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }
    function accountPath(uid) { return /databases/$(database)/documents/users/$(uid); }
    function profilePath(uid) { return /databases/$(database)/documents/profiles/$(uid); }
    function validText(value, maxSize, required) {
      return value is string
        && value.size() <= maxSize
        && (!required || value.size() > 0);
    }
    function validHttpsOrEmpty(value) {
      return value is string
        && value.size() <= 2000
        && (value == '' || value.matches('^https://[^\\s<>]+$'));
    }
    function validPublicRole(value) {
      let role = get(accountPath(request.auth.uid)).data.get('role', 'user');
      return validText(value, 80, true)
        && ((role == 'admin' && value == 'Administrator')
          || (role == 'moderator' && value == 'Moderator')
          || (role == 'user' && !(value in ['Administrator', 'Moderator'])));
    }
    function validProfileData(data, uid) {
      return data.uid == uid
        && validText(data.get('fullName', ''), 100, true)
        && validText(data.get('shortName', ''), 30, true)
        && validText(data.get('city', ''), 80, false)
        && validText(data.get('profession', ''), 80, false)
        && validText(data.get('bio', ''), 500, false)
        && validText(data.get('school', ''), 120, false)
        && validHttpsOrEmpty(data.get('avatarURL', ''));
    }
    function validPostContent(data) {
      return validText(data.get('text', ''), 5000, false)
        && validHttpsOrEmpty(data.get('imageURL', ''))
        && validHttpsOrEmpty(data.get('videoURL', ''))
        && (data.get('text', '').size() > 0
          || data.get('imageURL', '').size() > 0
          || data.get('videoURL', '').size() > 0)
        && data.get('visibility', 'public') in ['public', 'friends'];
    }
    function isAdmin() {
      return signedIn()
        && exists(accountPath(request.auth.uid))
        && get(accountPath(request.auth.uid)).data.get('role', 'user') == 'admin';
    }
    function isModeratorOrAdmin() {
      return signedIn()
        && exists(accountPath(request.auth.uid))
        && get(accountPath(request.auth.uid)).data.get('role', 'user') in ['moderator', 'admin'];
    }
    function conversationPath(id) {
      return /databases/$(database)/documents/conversations/$(id);
    }
    function isConversationMember(id) {
      return signedIn()
        && exists(conversationPath(id))
        && request.auth.uid in get(conversationPath(id)).data.participants;
    }
    function callPath(id) {
      return /databases/$(database)/documents/calls/$(id);
    }
    function isCallMember(id) {
      return signedIn()
        && exists(callPath(id))
        && (get(callPath(id)).data.callerId == request.auth.uid
          || get(callPath(id)).data.calleeId == request.auth.uid);
    }
    function validLikeCounterChange(postId) {
      let likePath = /databases/$(database)/documents/posts/$(postId)/likes/$(request.auth.uid);
      let beforeExists = exists(likePath);
      let afterExists = existsAfter(likePath);
      let oldCount = resource.data.get('likesCount', 0);
      let newCount = request.resource.data.get('likesCount', 0);
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'updatedAt'])
        && ((!beforeExists && afterExists && newCount == oldCount + 1)
          || (beforeExists && !afterExists && newCount == oldCount - 1 && newCount >= 0));
    }
    function validGroupMembershipChange() {
      let beforeMembers = resource.data.get('memberIds', []).toSet();
      let afterMembers = request.resource.data.get('memberIds', []).toSet();
      let added = afterMembers.difference(beforeMembers);
      let removed = beforeMembers.difference(afterMembers);
      let oldCount = resource.data.get('membersCount', beforeMembers.size());
      let newCount = request.resource.data.get('membersCount', afterMembers.size());
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'membersCount', 'updatedAt'])
        && ((added.size() == 1 && added.hasAll([request.auth.uid]) && removed.size() == 0 && newCount == oldCount + 1)
          || (removed.size() == 1 && removed.hasAll([request.auth.uid]) && added.size() == 0 && newCount == oldCount - 1 && newCount >= 0));
    }
    function validEventAttendanceChange() {
      let beforeAttendees = resource.data.get('attendeeIds', []).toSet();
      let afterAttendees = request.resource.data.get('attendeeIds', []).toSet();
      let added = afterAttendees.difference(beforeAttendees);
      let removed = beforeAttendees.difference(afterAttendees);
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendeeIds', 'updatedAt'])
        && ((added.size() == 1 && added.hasAll([request.auth.uid]) && removed.size() == 0)
          || (removed.size() == 1 && removed.hasAll([request.auth.uid]) && added.size() == 0));
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.get('role', 'user') == 'user'
        && request.resource.data.get('status', 'active') == 'active';
      allow update: if (isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.get('role', 'user') == resource.data.get('role', 'user')
        && request.resource.data.get('status', 'active') == resource.data.get('status', 'active')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email', 'displayName', 'photoURL', 'lastLogin', 'updatedAt']))
        || (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'status', 'updatedAt']));
      allow delete: if false;
    }

    match /profiles/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && !request.resource.data.keys().hasAny(['role', 'status', 'admin', 'email'])
        && validProfileData(request.resource.data, uid);
      allow update: if isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && !request.resource.data.keys().hasAny(['role', 'status', 'admin', 'email'])
        && validProfileData(request.resource.data, uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fullName', 'shortName', 'email', 'avatarURL', 'city', 'bio', 'school',
          'graduationYear', 'profession', 'online', 'lastSeen', 'updatedAt'
        ]);
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.get('likesCount', 0) == 0
        && request.resource.data.get('commentsCount', 0) == 0
        && exists(accountPath(request.auth.uid))
        && exists(profilePath(request.auth.uid))
        && validText(request.resource.data.get('authorName', ''), 100, true)
        && validHttpsOrEmpty(request.resource.data.get('authorAvatar', ''))
        && validPublicRole(request.resource.data.get('authorRole', ''))
        && validPostContent(request.resource.data);
      allow update: if (signedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'text', 'imageURL', 'videoURL', 'visibility', 'updatedAt'
        ])
        && validPostContent(request.resource.data))
        || validLikeCounterChange(postId)
        || (isModeratorOrAdmin()
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'visibility', 'moderationStatus', 'moderationReason', 'updatedAt'
          ]));
      allow delete: if (signedIn() && resource.data.authorId == request.auth.uid) || isModeratorOrAdmin();

      match /likes/{uid} {
        allow read: if signedIn();
        allow create: if isSelf(uid)
          && request.resource.data.userId == request.auth.uid
          && getAfter(/databases/$(database)/documents/posts/$(postId)).data.get('likesCount', 0)
             == get(/databases/$(database)/documents/posts/$(postId)).data.get('likesCount', 0) + 1;
        allow delete: if isSelf(uid)
          && getAfter(/databases/$(database)/documents/posts/$(postId)).data.get('likesCount', 0)
             == get(/databases/$(database)/documents/posts/$(postId)).data.get('likesCount', 0) - 1;
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && validText(request.resource.data.get('authorName', ''), 100, true)
          && validHttpsOrEmpty(request.resource.data.get('authorAvatar', ''));
        allow update: if signedIn()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updatedAt'])
          && validText(request.resource.data.text, 2000, true);
        allow delete: if (signedIn() && resource.data.authorId == request.auth.uid) || isModeratorOrAdmin();
      }
    }

    match /friendships/{friendshipId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.resource.data.fromUser == request.auth.uid
        && request.resource.data.toUser != request.auth.uid
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants.hasAll([request.resource.data.fromUser, request.resource.data.toUser])
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && resource.data.status == 'pending'
        && resource.data.toUser == request.auth.uid
        && request.resource.data.status in ['accepted', 'rejected']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if signedIn() && request.auth.uid in resource.data.participants;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.resource.data.type == 'direct'
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants[0] != request.resource.data.participants[1]
        && request.auth.uid in request.resource.data.participants;
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage', 'lastMessageAt', 'lastMessageSenderId', 'updatedAt'
        ])
        && validText(request.resource.data.get('lastMessage', ''), 4000, true)
        && request.resource.data.lastMessageSenderId == request.auth.uid;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationMember(conversationId);
        allow create: if isConversationMember(conversationId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 4000
          && request.resource.data.seenBy == [request.auth.uid];
        allow update: if isConversationMember(conversationId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenBy'])
          && request.resource.data.get('seenBy', []).toSet().hasAll(resource.data.get('seenBy', []).toSet())
          && request.resource.data.get('seenBy', []).toSet().difference(resource.data.get('seenBy', []).toSet()).size() == 1
          && request.resource.data.get('seenBy', []).toSet().difference(resource.data.get('seenBy', []).toSet()).hasAll([request.auth.uid]);
        allow delete: if signedIn() && resource.data.senderId == request.auth.uid;
      }

      match /typing/{uid} {
        allow read: if isConversationMember(conversationId);
        allow create, update: if isSelf(uid)
          && isConversationMember(conversationId)
          && request.resource.data.active == true;
        allow delete: if isSelf(uid) && isConversationMember(conversationId);
      }
    }

    match /calls/{callId} {
      allow read: if signedIn()
        && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.callerId == request.auth.uid
        && request.resource.data.calleeId != request.auth.uid
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants.hasAll([
          request.resource.data.callerId, request.resource.data.calleeId
        ])
        && request.resource.data.type == 'video'
        && request.resource.data.status == 'ringing'
        && request.resource.data.offer is map;
      allow update: if signedIn()
        && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid)
        && request.resource.data.callerId == resource.data.callerId
        && request.resource.data.calleeId == resource.data.calleeId
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'answer', 'status', 'updatedAt', 'endedAt'
        ])
        && ((request.auth.uid == resource.data.calleeId
            && resource.data.status == 'ringing'
            && request.resource.data.status in ['accepted', 'declined', 'busy'])
          || (request.resource.data.status == 'ended'));
      allow delete: if false;

      match /callerCandidates/{candidateId} {
        allow read: if isCallMember(callId);
        allow create: if isCallMember(callId)
          && get(callPath(callId)).data.callerId == request.auth.uid;
        allow update, delete: if false;
      }
      match /calleeCandidates/{candidateId} {
        allow read: if isCallMember(callId);
        allow create: if isCallMember(callId)
          && get(callPath(callId)).data.calleeId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.userId != request.auth.uid
        && request.resource.data.type in [
          'message', 'friend_request', 'friend_accepted', 'like', 'comment', 'video_call'
        ]
        && request.resource.data.page in ['feed', 'classmates', 'messages']
        && request.resource.data.read == false
        && validText(request.resource.data.text, 240, true)
        && validText(request.resource.data.get('icon', ''), 12, false)
        && validText(request.resource.data.get('targetId', ''), 200, false);
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds == [request.auth.uid]
        && request.resource.data.membersCount == 1
        && validText(request.resource.data.name, 80, true)
        && validText(request.resource.data.get('icon', ''), 8, false)
        && validText(request.resource.data.get('description', ''), 300, false);
      allow update: if (signedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'icon', 'description', 'updatedAt'])
        && validText(request.resource.data.name, 80, true)
        && validText(request.resource.data.get('icon', ''), 8, false)
        && validText(request.resource.data.get('description', ''), 300, false))
        || validGroupMembershipChange();
      allow delete: if (signedIn() && resource.data.ownerId == request.auth.uid) || isModeratorOrAdmin();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.attendeeIds == [request.auth.uid]
        && validText(request.resource.data.title, 120, true)
        && validText(request.resource.data.date, 10, true)
        && request.resource.data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && validText(request.resource.data.time, 5, true)
        && request.resource.data.time.matches('^\\d{2}:\\d{2}$')
        && validText(request.resource.data.location, 180, true)
        && validText(request.resource.data.get('description', ''), 500, false);
      allow update: if (signedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title', 'date', 'time', 'location', 'description', 'updatedAt'
        ])
        && validText(request.resource.data.title, 120, true)
        && validText(request.resource.data.date, 10, true)
        && request.resource.data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && validText(request.resource.data.time, 5, true)
        && request.resource.data.time.matches('^\\d{2}:\\d{2}$')
        && validText(request.resource.data.location, 180, true)
        && validText(request.resource.data.get('description', ''), 500, false))
        || validEventAttendanceChange();
      allow delete: if (signedIn() && resource.data.ownerId == request.auth.uid) || isModeratorOrAdmin();
    }

    match /media/{mediaId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.type in ['image', 'video']
        && validText(request.resource.data.get('title', ''), 100, false)
        && validHttpsOrEmpty(request.resource.data.src)
        && request.resource.data.src != '';
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'src', 'type', 'updatedAt'])
        && request.resource.data.type in ['image', 'video']
        && validText(request.resource.data.get('title', ''), 100, false)
        && validHttpsOrEmpty(request.resource.data.src)
        && request.resource.data.src != '';
      allow delete: if (signedIn() && resource.data.ownerId == request.auth.uid) || isModeratorOrAdmin();
    }

    match /stories/{storyId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && validText(request.resource.data.get('text', ''), 500, false)
        && validText(request.resource.data.get('ownerName', ''), 100, true)
        && validHttpsOrEmpty(request.resource.data.get('ownerAvatar', ''))
        && validHttpsOrEmpty(request.resource.data.media)
        && request.resource.data.media != '';
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'media', 'updatedAt'])
        && validText(request.resource.data.get('text', ''), 500, false)
        && validHttpsOrEmpty(request.resource.data.media)
        && request.resource.data.media != '';
      allow delete: if (signedIn() && resource.data.ownerId == request.auth.uid) || isModeratorOrAdmin();
    }

    match /{document=**} { allow read, write: if false; }
  }
}
